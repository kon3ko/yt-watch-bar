{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.1",
  "description": "__MSG_appDesc__",
  "author": "kon3ko",
  "default_locale": "en",
  "icons": {
    "64": "icon64.png"
  },
  "permissions": [
    "storage"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
